# Local runtime settings
AMA_DATA_DIRECTORY=./data
AMA_API_PORT=8000
AMA_WEB_PORT=3000
AMA_MAX_DOCUMENT_SIZE_MB=25
AMA_SUPPORTED_FILE_TYPES=.pdf,.txt,.md,.png,.jpg,.jpeg
AMA_CHUNK_SIZE_TOKENS=300
AMA_CHUNK_OVERLAP_TOKENS=40
AMA_PARENT_CHUNK_SIZE_TOKENS=900
AMA_CHUNK_TOKEN_ENCODING=cl100k_base
AMA_LOG_LEVEL=INFO

# OCR runs locally. Digital PDF pages retain their embedded text layer.
AMA_OCR_PROVIDER=tesseract
AMA_OCR_LANGUAGE=eng
AMA_OCR_DPI=300
AMA_OCR_PAGE_TIMEOUT_SECONDS=30
AMA_OCR_MAX_PAGES=100
AMA_OCR_MAX_IMAGE_PIXELS=50000000

# Visual analysis is opt-in because rendered document pages are sent to OpenAI.
AMA_VISUAL_ANALYSIS_PROVIDER=none
AMA_VISUAL_ANALYSIS_MODEL=gpt-5.6-terra
AMA_VISUAL_ANALYSIS_DETAIL=high
AMA_VISUAL_ANALYSIS_RENDER_DPI=150
AMA_VISUAL_ANALYSIS_TIMEOUT_SECONDS=60
AMA_VISUAL_ANALYSIS_MAX_PAGES=100
AMA_VISUAL_ANALYSIS_MAX_IMAGE_PIXELS=25000000
AMA_VISUAL_ANALYSIS_MAX_OUTPUT_TOKENS=1000

# Embeddings are opt-in because document chunks are sent to the configured provider.
AMA_EMBEDDING_PROVIDER=none
AMA_EMBEDDING_MODEL=text-embedding-3-small
AMA_EMBEDDING_DIMENSIONS=512
AMA_EMBEDDING_BATCH_SIZE=128
AMA_EMBEDDING_CACHE_MAX_ENTRIES=10000

# SQLite uses WAL for concurrent API and worker access. This bounds lock waits.
AMA_SQLITE_BUSY_TIMEOUT_MS=5000
AMA_VECTOR_STORE=qdrant
AMA_QDRANT_TIMEOUT_SECONDS=5
AMA_QDRANT_PORT=6333

# Hybrid retrieval combines semantic vectors with local SQLite full-text search.
AMA_RETRIEVAL_CANDIDATE_LIMIT=30
AMA_RETRIEVAL_RRF_K=60
AMA_RETRIEVAL_SEMANTIC_WEIGHT=1
AMA_RETRIEVAL_TEXT_WEIGHT=1

# Optional second-stage relevance scoring over the bounded hybrid candidate set.
AMA_RERANK_PROVIDER=none
AMA_RERANK_MODEL=gpt-5.6-terra
AMA_RERANK_CANDIDATE_LIMIT=15
AMA_RERANK_MIN_SCORE=0.25
AMA_RERANK_MAX_OUTPUT_TOKENS=1000

# Grounded answers are opt-in and require embeddings for local evidence retrieval.
AMA_ANSWER_PROVIDER=none
AMA_ANSWER_MODEL=gpt-5.6-terra
AMA_ANSWER_MAX_OUTPUT_TOKENS=1000

# OpenAI visual analysis, embeddings, reranking and answers share this credential.
# OPENAI_API_KEY=replace-me

# The Next.js server uses this internally. Docker Compose sets it to the API service.
# AMA_API_BASE_URL=http://127.0.0.1:8000
